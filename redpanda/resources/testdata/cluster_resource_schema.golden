        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: enabled
          type: BoolAttribute
          optional: true
          computed: true
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
          default: booldefault.staticBoolDefault
        - name: replicas
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
          default: int32default.staticInt32Default
        - name: url
          type: StringAttribute
          computed: true
    - name: schema_registry
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: all_urls
          type: SingleNestedAttribute
          computed: true
          plan_modifiers:
            - objectplanmodifier.useNonNullStateForUnknown
          attributes:
            - name: mtls
              type: StringAttribute
              computed: true
              plan_modifiers:
                - stringplanmodifier.useNonNullStateForUnknown
            - name: private_link_mtls
              type: StringAttribute
              computed: true
              plan_modifiers:
                - stringplanmodifier.useNonNullStateForUnknown
            - name: private_link_sasl
              type: StringAttribute
              computed: true
              plan_modifiers:
                - stringplanmodifier.useNonNullStateForUnknown
            - name: sasl
              type: StringAttribute
              computed: true
              plan_modifiers:
                - stringplanmodifier.useNonNullStateForUnknown
        - name: mtls
          type: SingleNestedAttribute
          optional: true
          attributes:
            - name: ca_certificates_pem
              type: ListAttribute
              optional: true
              element_type: basetypes.StringType
            - name: enabled
              type: BoolAttribute
              optional: true
              computed: true
              default: booldefault.staticBoolDefault
            - name: principal_mapping_rules
              type: ListAttribute
              optional: true
              element_type: basetypes.StringType
        - name: url
          type: StringAttribute
          computed: true
          plan_modifiers:
            - stringplanmodifier.useNonNullStateForUnknown
    - name: state
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: state_description
      type: SingleNestedAttribute
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: code
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: message
          type: StringAttribute
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
    - name: tags
      type: MapAttribute
      optional: true
      computed: true
      plan_modifiers:
        - mapplanmodifier.useStateForUnknownModifier
      element_type: basetypes.StringType
    - name: throughput_tier
      type: StringAttribute
      required: true
    - name: zones
      type: ListAttribute
      required: true
      validators:
        - validators.AWSZoneIDValidator
      plan_modifiers:
        - listplanmodifier.requiresReplaceIfModifier
      element_type: basetypes.StringType

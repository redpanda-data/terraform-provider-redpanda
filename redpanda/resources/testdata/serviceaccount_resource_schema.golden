has_timeouts: true
attributes:
    - name: auth0_client_credentials
      type: SingleNestedAttribute
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: client_id
          type: StringAttribute
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: client_secret
          type: StringAttribute
          computed: true
          sensitive: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
    - name: description
      type: StringAttribute
      required: true
    - name: id
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: name
      type: StringAttribute
      required: true

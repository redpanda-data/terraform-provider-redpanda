has_timeouts: true
attributes:
    - name: auth0_client_credentials
      type: SingleNestedAttribute
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: client_id
          type: StringAttribute
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: client_secret
          type: StringAttribute
          computed: true
          sensitive: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
    - name: description
      type: StringAttribute
      required: true
    - name: id
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: name
      type: StringAttribute
      required: true
    - name: role_bindings
      type: ListNestedAttribute
      optional: true
      plan_modifiers:
        - listplanmodifier.requiresReplaceIfModifier
      attributes:
        - name: role_name
          type: StringAttribute
          required: true
        - name: scope
          type: SingleNestedAttribute
          required: true
          attributes:
            - name: dataplane_id
              type: StringAttribute
              optional: true
            - name: resource_id
              type: StringAttribute
              required: true
            - name: resource_type
              type: StringAttribute
              required: true

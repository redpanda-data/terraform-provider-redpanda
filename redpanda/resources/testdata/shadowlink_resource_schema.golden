has_timeouts: true
attributes:
    - name: allow_deletion
      type: BoolAttribute
      optional: true
      computed: true
      default: booldefault.staticBoolDefault
    - name: client_options
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: authentication_configuration
          type: SingleNestedAttribute
          optional: true
          computed: true
          plan_modifiers:
            - objectplanmodifier.useStateForUnknownModifier
          attributes:
            - name: plain_configuration
              type: SingleNestedAttribute
              optional: true
              computed: true
              plan_modifiers:
                - objectplanmodifier.useStateForUnknownModifier
              attributes:
                - name: password
                  type: StringAttribute
                  optional: true
                  computed: true
                  sensitive: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
                - name: password_set
                  type: BoolAttribute
                  computed: true
                  plan_modifiers:
                    - boolplanmodifier.useNonNullStateForUnknown
                - name: username
                  type: StringAttribute
                  optional: true
                  computed: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
            - name: scram_configuration
              type: SingleNestedAttribute
              optional: true
              computed: true
              plan_modifiers:
                - objectplanmodifier.useStateForUnknownModifier
              attributes:
                - name: password
                  type: StringAttribute
                  optional: true
                  computed: true
                  sensitive: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
                - name: password_set
                  type: BoolAttribute
                  computed: true
                  plan_modifiers:
                    - boolplanmodifier.useNonNullStateForUnknown
                - name: scram_mechanism
                  type: StringAttribute
                  optional: true
                  computed: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
                - name: username
                  type: StringAttribute
                  optional: true
                  computed: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
        - name: bootstrap_servers
          type: ListAttribute
          optional: true
          computed: true
          plan_modifiers:
            - listplanmodifier.useStateForUnknownModifier
          element_type: basetypes.StringType
        - name: client_id
          type: StringAttribute
          computed: true
          plan_modifiers:
            - stringplanmodifier.useNonNullStateForUnknown
        - name: connection_timeout_ms
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: effective_connection_timeout_ms
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: effective_fetch_max_bytes
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: effective_fetch_min_bytes
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: effective_fetch_partition_max_bytes
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: effective_fetch_wait_max_ms
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: effective_metadata_max_age_ms
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: effective_retry_backoff_ms
          type: Int32Attribute
          computed: true
          plan_modifiers:
            - int32planmodifier.useNonNullStateForUnknown
        - name: fetch_max_bytes
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: fetch_min_bytes
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: fetch_partition_max_bytes
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: fetch_wait_max_ms
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: metadata_max_age_ms
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: retry_backoff_ms
          type: Int32Attribute
          optional: true
          computed: true
          plan_modifiers:
            - int32planmodifier.useStateForUnknownModifier
        - name: source_cluster_id
          type: StringAttribute
          optional: true
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: tls_settings
          type: SingleNestedAttribute
          optional: true
          computed: true
          plan_modifiers:
            - objectplanmodifier.useStateForUnknownModifier
          attributes:
            - name: ca
              type: StringAttribute
              optional: true
              computed: true
              plan_modifiers:
                - stringplanmodifier.useStateForUnknownModifier
            - name: cert
              type: StringAttribute
              optional: true
              computed: true
              plan_modifiers:
                - stringplanmodifier.useStateForUnknownModifier
            - name: do_not_set_sni_hostname
              type: BoolAttribute
              optional: true
              computed: true
              plan_modifiers:
                - boolplanmodifier.useStateForUnknownModifier
            - name: enabled
              type: BoolAttribute
              optional: true
              computed: true
              plan_modifiers:
                - boolplanmodifier.useStateForUnknownModifier
            - name: key
              type: StringAttribute
              optional: true
              computed: true
              sensitive: true
              plan_modifiers:
                - stringplanmodifier.useStateForUnknownModifier
    - name: consumer_offset_sync_options
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: group_filters
          type: ListNestedAttribute
          optional: true
          computed: true
          plan_modifiers:
            - listplanmodifier.useStateForUnknownModifier
          attributes:
            - name: filter_type
              type: StringAttribute
              required: true
            - name: name
              type: StringAttribute
              required: true
            - name: pattern_type
              type: StringAttribute
              required: true
        - name: interval
          type: StringAttribute
          optional: true
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: paused
          type: BoolAttribute
          optional: true
          computed: true
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
    - name: id
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: name
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: reason
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: schema_registry_sync_options
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: shadow_schema_registry_topic
          type: BoolAttribute
          optional: true
          computed: true
          validators:
            - boolvalidator.equalsValidator
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
    - name: security_sync_options
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: acl_filters
          type: ListNestedAttribute
          optional: true
          computed: true
          plan_modifiers:
            - listplanmodifier.useStateForUnknownModifier
          attributes:
            - name: access_filter
              type: SingleNestedAttribute
              required: true
              attributes:
                - name: host
                  type: StringAttribute
                  optional: true
                  computed: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
                - name: operation
                  type: StringAttribute
                  required: true
                - name: permission_type
                  type: StringAttribute
                  required: true
                - name: principal
                  type: StringAttribute
                  optional: true
                  computed: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
            - name: resource_filter
              type: SingleNestedAttribute
              required: true
              attributes:
                - name: name
                  type: StringAttribute
                  optional: true
                  computed: true
                  plan_modifiers:
                    - stringplanmodifier.useStateForUnknownModifier
                - name: pattern_type
                  type: StringAttribute
                  required: true
                - name: resource_type
                  type: StringAttribute
                  required: true
        - name: interval
          type: StringAttribute
          optional: true
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: paused
          type: BoolAttribute
          optional: true
          computed: true
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
    - name: shadow_redpanda_id
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: source_redpanda_id
      type: StringAttribute
      optional: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: state
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: topic_metadata_sync_options
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: auto_create_shadow_topic_filters
          type: ListNestedAttribute
          optional: true
          computed: true
          plan_modifiers:
            - listplanmodifier.useStateForUnknownModifier
          attributes:
            - name: filter_type
              type: StringAttribute
              required: true
            - name: name
              type: StringAttribute
              required: true
            - name: pattern_type
              type: StringAttribute
              required: true
        - name: exclude_default
          type: BoolAttribute
          optional: true
          computed: true
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
        - name: interval
          type: StringAttribute
          optional: true
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: paused
          type: BoolAttribute
          optional: true
          computed: true
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
        - name: start_at_earliest
          type: BoolAttribute
          optional: true
          computed: true
          validators:
            - boolvalidator.equalsValidator
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
        - name: start_at_latest
          type: BoolAttribute
          optional: true
          computed: true
          validators:
            - boolvalidator.equalsValidator
          plan_modifiers:
            - boolplanmodifier.useStateForUnknownModifier
        - name: start_at_timestamp
          type: StringAttribute
          optional: true
          computed: true
          plan_modifiers:
            - stringplanmodifier.useStateForUnknownModifier
        - name: synced_shadow_topic_properties
          type: ListAttribute
          optional: true
          computed: true
          plan_modifiers:
            - listplanmodifier.useStateForUnknownModifier
          element_type: basetypes.StringType

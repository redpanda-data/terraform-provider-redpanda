attributes:
    - name: allow_deletion
      type: BoolAttribute
      optional: true
      computed: true
      default: booldefault.staticBoolDefault
    - name: cluster_api_url
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: delete_acls
      type: BoolAttribute
      optional: true
      computed: true
      default: booldefault.staticBoolDefault
    - name: id
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: name
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier

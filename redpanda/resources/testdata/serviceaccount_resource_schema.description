description: A Redpanda Cloud service account (machine identity)
attributes:
    - name: auth0_client_credentials
      description: Auth0 Client Credentials configuration
      attributes:
        - name: client_id
          description: The client ID of the credentials
        - name: client_secret
          description: The client secret
    - name: description
      description: The description of the service_account. Length must be at most 140.
    - name: id
      description: Unique identifier of the resource.
    - name: name
      description: The unique name of the service account. Length must be between 3 and 128. Must match pattern `^[^<>]+$`.

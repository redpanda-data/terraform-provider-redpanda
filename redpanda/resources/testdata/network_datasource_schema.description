description: Data source for a Redpanda Cloud network
attributes:
    - name: cidr_block
      description: The cidr_block to create the network in
    - name: cloud_provider
      description: The cloud provider to create the network in. Can also be set at the provider level
    - name: cluster_type
      description: The type of cluster this network is associated with, can be one of dedicated or cloud
    - name: customer_managed_resources
      description: Cloud resources created by user.
      attributes:
        - name: aws
          description: The AWS resources managed by user.
          attributes:
            - name: dynamodb_table
              description: AWS DynamoDB table specification.
              attributes:
                - name: arn
                  description: AWS DynamoDB table identifier.
            - name: management_bucket
              description: AWS storage bucket properties by ARN.
              attributes:
                - name: arn
                  description: AWS storage bucket identifier.
            - name: private_subnets
              description: AWS Subnets Specification
              attributes:
                - name: arns
                  description: AWS private subnet identifiers
            - name: vpc
              description: AWS VPC Specification
              attributes:
                - name: arn
                  description: AWS VPC identifier.
        - name: gcp
          description: GCP resources created and managed by user, and required to deploy the Redpanda cluster. See [Create a BYOVPC Cluster on GCP](https://docs.redpanda.com/redpanda-cloud/get-started/cluster-types/byoc/gcp/vpc-byo-gcp/) for details.
          attributes:
            - name: management_bucket
              description: GCP storage bucket properties.
              attributes:
                - name: name
                  description: GCP storage bucket name for storing the state of Redpanda cluster deployment
            - name: network_name
              description: Name of user-created network where the Redpanda cluster is deployed to. See the official [GCP API reference](https://cloud.google.com/compute/docs/reference/rest/v1/networks).
            - name: network_project_id
              description: GCP project ID where the network is created.
    - name: id
      description: UUID of the network
    - name: name
      description: Name of the network
    - name: region
      description: The region to create the network in. Can also be set at the provider level
    - name: resource_group_id
      description: The ID of the resource group in which to create the network
    - name: state
      description: Current state of the network.
    - name: zones
      description: Network availability zones.

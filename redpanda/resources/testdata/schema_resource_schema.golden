attributes:
    - name: allow_deletion
      type: BoolAttribute
      optional: true
      computed: true
      default: booldefault.staticBoolDefault
    - name: cluster_id
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: compatibility
      type: StringAttribute
      optional: true
      computed: true
      validators:
        - stringvalidator.oneOfCaseInsensitiveValidator
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: id
      type: Int64Attribute
      computed: true
    - name: password
      type: StringAttribute
      optional: true
      sensitive: true
    - name: password_wo
      type: StringAttribute
      optional: true
      write_only: true
      deprecation_message: 'password_wo cannot be used reliably with redpanda_schema: write-only attributes are not available at refresh time, so the provider cannot authenticate to Schema Registry during plan. Use cloud Bearer authentication (omit username + password) or the `password` attribute instead.'
    - name: password_wo_version
      type: Int64Attribute
      optional: true
      deprecation_message: password_wo_version is paired with password_wo, which is deprecated. See the password_wo deprecation message for migration guidance.
      plan_modifiers:
        - int64planmodifier.useStateForUnknownModifier
    - name: references
      type: ListNestedAttribute
      optional: true
      plan_modifiers:
        - listplanmodifier.useStateForUnknownModifier
      attributes:
        - name: name
          type: StringAttribute
          required: true
        - name: subject
          type: StringAttribute
          required: true
        - name: version
          type: Int64Attribute
          required: true
    - name: schema
      type: StringAttribute
      required: true
    - name: schema_type
      type: StringAttribute
      optional: true
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: subject
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: username
      type: StringAttribute
      optional: true
      sensitive: true
    - name: version
      type: Int64Attribute
      computed: true

has_timeouts: true
attributes:
    - name: allow_deletion
      type: BoolAttribute
      optional: true
      computed: true
      default: booldefault.staticBoolDefault
    - name: aws_config
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: allowed_principals
          type: ListAttribute
          required: true
          validators:
            - listvalidator.sizeAtLeastValidator
          element_type: basetypes.StringType
    - name: cloud_provider
      type: StringAttribute
      required: true
      validators:
        - stringvalidator.oneOfValidator
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: cloud_provider_config
      type: SingleNestedAttribute
      optional: true
      deprecation_message: |-
        cloud_provider_config has been replaced by aws_config. Move your configuration from cloud_provider_config.aws to aws_config.

        None of this serverless private link resource's attributes are marked RequiresReplace, so updating in place is safe. To guarantee the transition will be a no-op, use terraform state rm followed by terraform import on each affected serverless private link resource:

          terraform state rm redpanda_serverless_private_link.<resource_name>
          terraform import redpanda_serverless_private_link.<resource_name> <serverless_private_link_id>
      validators:
        - validators.ServerlessPrivateLinkConfigRemovedValidator
      attributes:
        - name: aws
          type: SingleNestedAttribute
          optional: true
          attributes:
            - name: allowed_principals
              type: ListAttribute
              optional: true
              element_type: basetypes.StringType
    - name: id
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: name
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: resource_group_id
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: serverless_region
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: state
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: status
      type: SingleNestedAttribute
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: aws
          type: SingleNestedAttribute
          computed: true
          plan_modifiers:
            - objectplanmodifier.useStateForUnknownModifier
          attributes:
            - name: availability_zones
              type: ListAttribute
              computed: true
              plan_modifiers:
                - listplanmodifier.useStateForUnknownModifier
              element_type: basetypes.StringType
            - name: vpc_endpoint_service_name
              type: StringAttribute
              computed: true
              plan_modifiers:
                - stringplanmodifier.useStateForUnknownModifier

has_timeouts: true
attributes:
    - name: allow_deletion
      type: BoolAttribute
      optional: true
      computed: true
      default: booldefault.staticBoolDefault
    - name: aws_config
      type: SingleNestedAttribute
      optional: true
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: allowed_principals
          type: ListAttribute
          required: true
          validators:
            - listvalidator.sizeAtLeastValidator
          element_type: basetypes.StringType
    - name: cloud_provider
      type: StringAttribute
      required: true
      validators:
        - stringvalidator.oneOfValidator
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: id
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: name
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: resource_group_id
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: serverless_region
      type: StringAttribute
      required: true
      plan_modifiers:
        - stringplanmodifier.requiresReplaceIfModifier
    - name: state
      type: StringAttribute
      computed: true
      plan_modifiers:
        - stringplanmodifier.useStateForUnknownModifier
    - name: status
      type: SingleNestedAttribute
      computed: true
      plan_modifiers:
        - objectplanmodifier.useStateForUnknownModifier
      attributes:
        - name: aws
          type: SingleNestedAttribute
          computed: true
          plan_modifiers:
            - objectplanmodifier.useStateForUnknownModifier
          attributes:
            - name: availability_zones
              type: ListAttribute
              computed: true
              plan_modifiers:
                - listplanmodifier.useStateForUnknownModifier
              element_type: basetypes.StringType
            - name: vpc_endpoint_service_name
              type: StringAttribute
              computed: true
              plan_modifiers:
                - stringplanmodifier.useStateForUnknownModifier
